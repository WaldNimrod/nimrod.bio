# nimrod.bio — WordPress local dev
# LOD400 §3.4 canonical patterns

# === Cross-project subdirs on uPress hosting (not WordPress — never track) ===
# These live under the same hosting root but belong to separate AOS projects.
# Excluded from git AND from restore rsync (project_identity.yaml §forbidden_patterns).
nimrod.bio/agents/
nimrod.bio/Agents/
nimrod.bio/famely_NL/
nimrod.bio/sfa-hub/
nimrod.bio/GitDirectory/
nimrod.bio/pub/

# === WordPress core (not tracked — rebuilt from backup or core download) ===
nimrod.bio/wp-admin/
nimrod.bio/wp-includes/
nimrod.bio/wp-*.php
nimrod.bio/index.php
nimrod.bio/xmlrpc.php

# === WordPress object/fragment cache files (runtime artefacts) ===
nimrod.bio/wp-content/advanced-cache.php
nimrod.bio/wp-content/object-cache.php
nimrod.bio/wp-content/ezcache-config.json

# === Secrets / production config ===
nimrod.bio/wp-config.php
nimrod.bio/wp-config-local.php
.env
.env.local

# === Uploads (binary content — too large, not in source control) ===
nimrod.bio/wp-content/uploads/

# === Backup sources (never commit backups or DB dumps) ===
sources/*.zip
sources/*.sql
sources/*.tar.gz
sources/*.gz

# === Restore work directory ===
.restore-work/

# === OS / editor ===
.DS_Store
Thumbs.db
*.swp
